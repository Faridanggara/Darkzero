<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1f3c">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🐛 BUG MENU"
            android:textColor="#00d4ff"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etTarget"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Target (nomor/ID)"
            android:textColorHint="#4a7a9c"
            android:textColor="#ffffff"
            android:background="@drawable/edittext_bg"
            android:paddingStart="16dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etSpamText"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Teks Spam (isi sendiri)"
            android:textColorHint="#4a7a9c"
            android:textColor="#ffffff"
            android:background="@drawable/edittext_bg"
            android:paddingStart="16dp"
            android:layout_marginBottom="16dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4">

            <Button
                android:id="@+id/btnCrash"
                style="@style/MenuButton"
                android:text="💥 CRASH" />

            <Button
                android:id="@+id/btnFreeze"
                style="@style/MenuButton"
                android:text="❄️ FREEZE" />

            <Button
                android:id="@+id/btnSpamText"
                style="@style/MenuButton"
                android:text="📨 SPAM TEXT" />

            <Button
                android:id="@+id/btnSpamOtp"
                style="@style/MenuButton"
                android:text="🔐 SPAM OTP" />

            <Button
                android:id="@+id/btnBannedGroup"
                style="@style/MenuButton"
                android:text="🚫 BANNED GROUP" />

            <Button
                android:id="@+id/btnBannedChannel"
                style="@style/MenuButton"
                android:text="📢 BANNED CHANNEL" />

        </GridLayout>

        <Button
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⬅ KEMBALI"
            android:backgroundTint="#1a2a4a"
            android:textColor="#4a7a9c"
            android:layout_marginTop="16dp"
            android:onClick="finish" />

    </LinearLayout>
</ScrollView>