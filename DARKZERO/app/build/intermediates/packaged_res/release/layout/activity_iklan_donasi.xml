<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d1f3c"
    android:padding="20dp"
    android:gravity="center">

    <TextView
        android:id="@+id/tvDonasi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💰 Support DARK ZERO"
        android:textColor="#00d4ff"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnDonasi"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="💳 DONASI SEKARANG"
        android:backgroundTint="#ffd93d"
        android:textColor="#0d1f3c"
        android:textStyle="bold"
        android:textSize="16sp" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="⬅ KEMBALI"
        android:backgroundTint="#1a2a4a"
        android:textColor="#4a7a9c"
        android:layout_marginTop="12dp"
        android:onClick="finish" />

</LinearLayout>