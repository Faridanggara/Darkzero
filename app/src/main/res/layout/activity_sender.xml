<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d1f3c"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📤 SENDER WA"
        android:textColor="#00d4ff"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etNomor"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Nomor WA (contoh: 628123456789)"
        android:textColorHint="#4a7a9c"
        android:textColor="#ffffff"
        android:background="@drawable/edittext_bg"
        android:paddingStart="16dp"
        android:layout_marginBottom="8dp"
        android:inputType="phone" />

    <Button
        android:id="@+id/btnMintaKode"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="📲 MINTA KODE"
        android:backgroundTint="#00d4ff"
        android:textColor="#0d1f3c"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etKode"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Kode dari WA"
        android:textColorHint="#4a7a9c"
        android:textColor="#ffffff"
        android:background="@drawable/edittext_bg"
        android:paddingStart="16dp"
        android:layout_marginBottom="8dp"
        android:inputType="number" />

    <Button
        android:id="@+id/btnVerifikasi"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="🔐 VERIFIKASI KODE"
        android:backgroundTint="#ffd93d"
        android:textColor="#0d1f3c"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnTautkan"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="🔗 TAUTKAN PERANGKAT"
        android:backgroundTint="#00d4ff"
        android:textColor="#0d1f3c"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚡ Status: Belum terhubung"
        android:textColor="#4a7a9c"
        android:textSize="14sp"
        android:gravity="center"
        android:background="#0a1a2e"
        android:padding="12dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="⬅ KEMBALI"
        android:backgroundTint="#1a2a4a"
        android:textColor="#4a7a9c"
        android:onClick="finish" />

</LinearLayout>