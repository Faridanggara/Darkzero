<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1f3c">

    <!-- Background Gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/banner_bg" />

    <!-- Logo -->
    <ImageView
        android:id="@+id/logoMain"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:src="@android:drawable/ic_menu_gallery"
        android:scaleType="fitCenter" />

    <!-- App Title -->
    <TextView
        android:id="@+id/tvTitleMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/logoMain"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="DARK ZERO"
        android:textColor="#00d4ff"
        android:textSize="34sp"
        android:textStyle="bold"
        android:letterSpacing="2" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitleMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTitleMain"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="6dp"
        android:text="Bug WA Tools"
        android:textColor="#4a7a9c"
        android:textSize="15sp"
        android:letterSpacing="1" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressMain"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_centerInParent="true"
        android:visibility="gone" />

    <!-- Tombol Mulai -->
    <Button
        android:id="@+id/btnStartMain"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="100dp"
        android:backgroundTint="#00d4ff"
        android:text="🚀 MULAI"
        android:textColor="#0d1f3c"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="28dp" />

    <!-- Footer -->
    <TextView
        android:id="@+id/tvFooterMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:text="Owner: Ridz | WA: 08819633945"
        android:textColor="#4a7a9c"
        android:textSize="12sp" />

</RelativeLayout>
